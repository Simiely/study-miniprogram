/* pages/index/index.wxss
   手机：2 列网格；平板(.tablet)：居中多列 */

.container { padding: 32rpx 24rpx 60rpx; min-height: 100vh; box-sizing: border-box; }

/* ---- 头部 ---- */
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 8rpx 28rpx; }
.hero { display: flex; flex-direction: column; }
.hero-logo { font-size: 64rpx; line-height: 1; margin-bottom: 10rpx; }
.hero-title { font-size: 44rpx; font-weight: 700; color: var(--text); letter-spacing: 1px; }
.hero-sub { font-size: 24rpx; color: var(--text-weak); margin-top: 6rpx; }

.stats-link {
  background: var(--card-bg); color: var(--primary);
  border: 4rpx solid var(--line); font-size: 28rpx;
  padding: 14rpx 30rpx; box-shadow: var(--shadow-soft);
}
.stats-link:active { border-color: var(--primary); transform: scale(0.96); }

/* ---- 板块列表：2 列网格 ---- */
.board-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.board-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
  background: var(--card-bg);
  border-radius: var(--radius-box);
  padding: 32rpx 30rpx;
  box-shadow: var(--shadow-soft);
  transition: transform 0.18s ease;
}
.board-item:active { transform: scale(0.975); }
.board-emoji { font-size: 64rpx; line-height: 1; }
.board-main { flex: 1; display: flex; flex-direction: column; min-width: 0; width: 100%; }
.board-title { font-size: 36rpx; color: var(--text); font-weight: 600; }
.board-sub { font-size: 24rpx; color: var(--text-weak); margin-top: 8rpx; }
.board-count {
  font-size: 24rpx; color: var(--primary); background: var(--primary-soft);
  padding: 6rpx 18rpx; border-radius: 999rpx; align-self: flex-start;
}

/* ---- 即将推出：灰色 + 降低透明度 ---- */
.board-item.coming { opacity: 0.5; filter: grayscale(0.6); }
.board-item.coming .board-count { background: #e8e3d8; color: var(--text-weak); }

.loading, .empty { text-align: center; color: var(--text-weak); font-size: 28rpx; margin-top: 120rpx; }

/* ============================================================
   平板布局 .tablet：2-3 列居中网格，组件尺寸与手机一致（px 单位）
   ============================================================ */
.tablet .container { padding: 40px 32px 64px; max-width: 900px; margin: 0 auto; }
.tablet .header { padding: 32px 8px 36px; }
.tablet .hero-logo { font-size: 72px; }
.tablet .hero-title { font-size: 48px; }
.tablet .hero-sub { font-size: 26px; }
.tablet .stats-link { font-size: 28px; padding: 14px 32px; border-width: 2px; }

.tablet .board-list {
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 28px;
}
.tablet .board-item { padding: 32px 30px; border-radius: 16px; }
.tablet .board-emoji { font-size: 64px; }
.tablet .board-title { font-size: 36px; }
.tablet .board-sub { font-size: 24px; }
.tablet .board-count { font-size: 24px; padding: 6px 18px; }
