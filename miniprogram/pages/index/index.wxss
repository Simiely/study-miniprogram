/* ============================================================
   pages/index/index.wxss
   ============================================================ */

/* ============================================================
   📱 手机端 — mockup px × 0.568 = rpx
   ============================================================ */

.content { padding: 25rpx 34rpx 51rpx; min-height: 100vh; box-sizing: border-box; }

.app-header { margin-bottom: 23rpx; }
.h-title { font-size: 48rpx; font-weight: 700; color: var(--text); }
.h-sub { font-size: 23rpx; color: var(--text-weak); margin-top: 8rpx; }

.section-title { font-size: 33rpx; font-weight: 700; margin: 5rpx 0 23rpx; display: flex; align-items: center; gap: 11rpx; }
.section-title::before { content: ''; width: 9rpx; height: 33rpx; background: var(--accent); border-radius: 5rpx; flex-shrink: 0; }

/* 板块网格 */
.home-grid { display: grid; gap: 27rpx; }
.home-grid.cols-2 { grid-template-columns: 1fr 1fr; gap: 25rpx; }

.board-card { background: var(--card-bg); border-radius: 41rpx; padding: 32rpx 28rpx; box-shadow: 0 6rpx 16rpx rgba(60,60,60,.10); position: relative; overflow: hidden; }
.board-card:active { transform: scale(0.97); }
.bc-emoji { font-size: 67rpx; line-height: 1; }
.bc-title { font-size: 36rpx; font-weight: 700; margin-top: 16rpx; color: var(--text); }
.bc-en { font-size: 23rpx; color: var(--text-weak); margin-top: 7rpx; }
.bc-tag { display: inline-block; margin-top: 17rpx; background: #eef2e6; color: var(--primary); font-size: 19rpx; font-weight: 600; padding: 9rpx 19rpx; border-radius: 999rpx; }

.board-card.coming { opacity: .45; filter: grayscale(.7); }
.board-card.coming .bc-tag { background: #e8e3d8; color: var(--text-weak); }

.loading, .empty { text-align: center; color: var(--text-weak); font-size: 16rpx; margin-top: 120rpx; }

/* ============================================================
   📲 iPad .tablet — 物理尺寸与 iPhone 一致（mockup px ÷3）
   ============================================================ */
.tablet .content { max-width: 367px; margin: 0 auto; padding: 15px 20px 30px; }

.tablet .app-header { margin-bottom: 13px; }
.tablet .h-title { font-size: 28px; }
.tablet .h-sub { font-size: 13px; margin-top: 5px; }

.tablet .section-title { font-size: 19px; margin: 3px 0 13px; gap: 7px; }
.tablet .section-title::before { width: 5px; height: 19px; border-radius: 3px; }

.tablet .home-grid { gap: 13px; }
.tablet .home-grid.cols-3 { grid-template-columns: repeat(3, 1fr); gap: 13px; }
.tablet .home-grid.cols-4 { grid-template-columns: repeat(4, 1fr); gap: 12px; }

.tablet .board-card { border-radius: 24px; padding: 19px 13px; box-shadow: 0 3px 9px rgba(60,60,60,.10); }
.tablet .bc-emoji { font-size: 39px; }
.tablet .bc-title { font-size: 21px; margin-top: 9px; }
.tablet .bc-en { font-size: 13px; margin-top: 4px; }
.tablet .bc-tag { font-size: 11px; padding: 5px 11px; margin-top: 10px; }
