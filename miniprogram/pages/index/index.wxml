<view class="page-root {{isTablet ? 'tablet' : ''}}">
  <view class="container">
    <view class="header">
      <view class="hero">
        <text class="hero-logo">📚</text>
        <text class="hero-title">学习卡片</text>
        <text class="hero-sub">边玩边学 · Word Cards</text>
      </view>
      <text class="stats-link pill" bindtap="goStats">📊 统计</text>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中…</view>

    <view wx:elif="{{boards.length === 0}}" class="empty">暂无板块</view>

    <view wx:else class="board-list">
      <view class="board-item {{item.status === 'coming' ? 'coming' : ''}}"
            wx:for="{{boards}}" wx:key="id"
            data-id="{{item.id}}"
            data-title="{{item.title}}"
            bindtap="onTapBoard">
        <text class="board-emoji">{{item.emoji}}</text>
        <view class="board-main">
          <text class="board-title">{{item.title}}</text>
          <text class="board-sub">{{item.desc}}</text>
        </view>
        <text class="board-count">{{item.cardCount > 0 ? item.cardCount + ' 张' : '即将推出'}}</text>
      </view>
    </view>
  </view>
</view>
