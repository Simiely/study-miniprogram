<view class="page-root {{isTablet ? 'tablet' : ''}}">
  <view class="content">
    <view class="app-header">
      <view class="h-title">学习卡片</view>
      <view class="h-sub">每天进步一点点</view>
    </view>

    <view class="section-title">
      <text class="section-icon"></text>
      <text>学习板块</text>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中…</view>
    <view wx:elif="{{boards.length === 0}}" class="empty">暂无板块</view>

    <!-- cols-2（手机）/ cols-3（iPad 竖屏）/ cols-4（iPad 横屏） -->
    <view wx:else class="home-grid
      {{isTablet ? (isLandscape ? 'cols-4' : 'cols-3') : 'cols-2'}}">
      <view class="board-card {{item.status === 'coming' ? 'coming' : ''}}"
            wx:for="{{boards}}" wx:key="id"
            data-id="{{item.id}}"
            data-title="{{item.title}}"
            bindtap="onTapBoard">
        <view class="bc-emoji">{{item.emoji}}</view>
        <view class="bc-title">{{item.title}}</view>
        <view class="bc-en">{{item.desc}}</view>
        <view class="bc-tag">{{item.cardCount > 0 ? item.cardCount + ' 张' : '即将推出'}}</view>
      </view>
    </view>
  </view>
</view>
