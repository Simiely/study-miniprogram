<view class="page-root {{isTablet ? 'tablet' : ''}}">
  <view class="content">
    <view class="app-header">
      <view class="h-title">今日统计</view>
      <view class="h-sub">{{date}}</view>
    </view>

    <!-- ===== 手机 + iPad 竖屏：center 布局 ===== -->
    <block wx:if="{{!isTablet || !isLandscape}}">
      <view class="stats-wrap center">
        <view class="stat-row">
          <view class="stat-tile">
            <view class="st-num">{{totalViews}}</view>
            <view class="st-label">总浏览次数</view>
          </view>
          <view class="stat-tile">
            <view class="st-num">{{distinctCards}}</view>
            <view class="st-label">看过卡片种类</view>
          </view>
        </view>
        <view class="top-list" wx:if="{{list.length > 0}}">
          <view class="tl-title">浏览最多的卡片</view>
          <view class="tl-item" wx:for="{{list}}" wx:key="id">
            <view class="tl-rank">{{index + 1}}</view>
            <view class="tl-name">{{item.name}}</view>
            <view class="tl-count">{{item.count}} 次</view>
          </view>
        </view>
        <view class="btn-clear" bindtap="onClear">清空今日统计</view>
      </view>
    </block>

    <!-- ===== iPad 横屏：split 左右分栏 ===== -->
    <block wx:else>
      <view class="stats-wrap split">
        <view class="col-left">
          <view class="stat-row">
            <view class="stat-tile">
              <view class="st-num">{{totalViews}}</view>
              <view class="st-label">总浏览次数</view>
            </view>
            <view class="stat-tile">
              <view class="st-num">{{distinctCards}}</view>
              <view class="st-label">看过卡片种类</view>
            </view>
          </view>
          <view class="btn-clear" bindtap="onClear">清空今日统计</view>
        </view>
        <view class="col-right">
          <view class="top-list" wx:if="{{list.length > 0}}">
            <view class="tl-title">浏览最多的卡片</view>
            <view class="tl-item" wx:for="{{list}}" wx:key="id">
              <view class="tl-rank">{{index + 1}}</view>
              <view class="tl-name">{{item.name}}</view>
              <view class="tl-count">{{item.count}} 次</view>
            </view>
          </view>
        </view>
      </view>
    </block>

  </view>
</view>
