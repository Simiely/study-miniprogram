/* pages/cards/cards.wxss - 卡片学习页样式
   翻面动画 + 卡片正面/背面布局 + 导航按钮 + 平板大屏适配 */

.container { padding: 24rpx; min-height: 100vh; box-sizing: border-box; }

/* ---- 顶栏 ---- */
.topbar { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.link-back, .link-stats {
  font-size: 26rpx; padding: 12rpx 24rpx; background: var(--card-bg);
  border: 2rpx solid var(--line); box-shadow: var(--shadow-soft);
}
.progress { font-size: 28rpx; color: var(--text-weak); font-weight: 600; }

.loading, .empty { text-align: center; color: var(--text-weak); font-size: 28rpx; margin-top: 200rpx; }

/* ---- 翻面卡片 ---- */
.card-area { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
.card {
  width: 100%; aspect-ratio: 0.75; max-height: 70vh; perspective: 1200rpx;
  margin: 20rpx 0; cursor: pointer;
}
.card-inner {
  position: relative; width: 100%; height: 100%; transition: transform 0.5s ease;
  transform-style: preserve-3d; border-radius: var(--radius-card);
}
.card.flipped .card-inner { transform: rotateY(180deg); }
.card-face {
  position: absolute; inset: 0; backface-visibility: hidden;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: var(--card-bg); border-radius: var(--radius-card);
  box-shadow: var(--shadow-card); padding: 40rpx;
}
.card-back { transform: rotateY(180deg); }
.card-label { font-size: 24rpx; color: var(--text-weak); margin-bottom: 20rpx; }
.card-text { font-size: 48rpx; font-weight: 700; color: var(--text); text-align: center; word-break: break-word; }
.card-hint { font-size: 22rpx; color: var(--text-weak); margin-top: 40rpx; }

/* ---- 导航按钮 ---- */
.nav { display: flex; gap: 20rpx; margin-top: 24rpx; }
.nav-btn {
  flex: 1; font-size: 28rpx; padding: 20rpx; border-radius: 999rpx;
  background: var(--card-bg); border: 2rpx solid var(--line); color: var(--text);
}
.nav-btn.primary { background: var(--primary); color: #fff; border-color: var(--primary); }

/* ============================================================
   平板布局 .tablet
   ============================================================ */
.tablet .container { max-width: 1000px; margin: 0 auto; padding: 32px; }
.tablet .card { max-height: 72vh; width: 480px; aspect-ratio: 0.7; }
.tablet .nav { gap: 28px; margin-top: 32px; }
.tablet .nav-btn { font-size: 28px; padding: 20px 40px; }
