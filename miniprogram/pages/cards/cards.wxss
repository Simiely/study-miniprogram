/* ============================================================
   pages/cards/cards.wxss
   ============================================================ */

/* ============================================================
   📱 手机端（默认）—— mockup px × 0.568 = rpx
   ============================================================ */

.content { padding: 25rpx 34rpx 51rpx; min-height: 100vh; box-sizing: border-box; }
.loading, .empty { text-align: center; color: var(--text-weak); font-size: 16rpx; margin-top: 120rpx; }

/* ===== 顶栏 mode-top ===== */
.mode-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 17rpx; }
.mode-top .badge { background: var(--primary); color: #fff; font-size: 20rpx; font-weight: 600; padding: 10rpx 25rpx; border-radius: 999rpx; white-space: nowrap; }
.mode-top .links { display: flex; gap: 10rpx; }
.mode-top .link { background: var(--card-bg); border: 1rpx solid #e0dcd4; color: var(--text); font-size: 19rpx; font-weight: 600; padding: 9rpx 18rpx; border-radius: 999rpx; white-space: nowrap; }
.mode-top .link:active { border-color: var(--primary); color: var(--primary); }
.mode-top .link.accent { border-color: var(--accent); color: var(--accent); }

/* ===== 浏览模式：方阵 ===== */
.browse-grid { display: grid; gap: 16rpx; margin-top: 5rpx; }
.browse-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }

.b-tile { aspect-ratio: 1; border-radius: 23rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; background: #3c2d12; }
.b-tile:active { transform: scale(.94); }
.b-tile .bt-emoji { font-size: 75rpx; line-height: 1.1; }
.b-tile .bt-name { font-size: 23rpx; color: #fff; font-weight: 600; margin-top: 8rpx; text-shadow: 0 1rpx 3rpx rgba(0,0,0,.35); }
.b-tile.visited { opacity: .1; }
.b-tile .bt-flag { position: absolute; top: 9rpx; right: 10rpx; font-size: 19rpx; color: #fff; background: rgba(0,0,0,.35); border-radius: 50%; width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; }

/* ===== 卡片模式（手机 flip-center） ===== */
.cards-content-phone { display: flex; flex-direction: column; height: 100%; }
.fc-counter { text-align: center; font-size: 24rpx; color: var(--text-weak); margin-bottom: 16rpx; font-weight: 600; }

.cards-stage { flex: 1; display: flex; align-items: center; justify-content: center; min-height: 0; }

/* flip-center */
.cards-stage.flip-center { position: relative; }
.cards-stage.flip-center .learn-card { width: 100%; height: 100%; }

/* 学习卡片（手机有白卡背景+圆角+阴影） */
.learn-card { background: var(--card-bg); border-radius: 41rpx; padding: 32rpx; box-shadow: 0 14rpx 34rpx rgba(74,124,89,.14); display: flex; flex-direction: column; }

/* 图片区 */
.learn-card .lc-image { flex: 1; min-height: 0; margin-bottom: 25rpx; background: linear-gradient(140deg,#eef3e4 0%,#dce7cf 100%); border-radius: 27rpx; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.learn-card .lc-image .lc-emoji { font-size: 295rpx; line-height: 1; }
.learn-card .lc-image .lc-ph { position: absolute; bottom: 15rpx; left: 0; right: 0; text-align: center; font-size: 18rpx; color: var(--text-weak); opacity: .72; }
.learn-card .lc-image .lc-zoom { position: absolute; bottom: 17rpx; right: 17rpx; width: 50rpx; height: 50rpx; z-index: 8; border-radius: 50%; background: rgba(255,255,255,.85); color: var(--primary); font-size: 25rpx; display: flex; align-items: center; justify-content: center; }
.learn-card .lc-image .lc-zoom:active { transform: scale(.94); }

/* 三段发音横幅 */
.learn-card .lc-texts { display: flex; flex-direction: column; gap: 13rpx; }
.lc-zhen { display: flex; gap: 13rpx; }
.lc-cell { flex: 1; min-width: 0; display: flex; align-items: center; justify-content: space-between; gap: 11rpx; padding: 17rpx 22rpx; background: #faf8f3; border-radius: 19rpx; }
.lc-cell:active { background: #f1ede4; transform: scale(.99); }
.lc-cell-zh .lc-zh { font-size: 50rpx; font-weight: 700; color: var(--text); line-height: 1.15; }
.lc-cell-en .lc-en { font-size: 50rpx; color: var(--text); line-height: 1.15; }
.lc-line { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; padding: 17rpx 22rpx; background: #faf8f3; border-radius: 19rpx; }
.lc-line:active { background: #f1ede4; transform: scale(.99); }
.lc-line .lc-fact { font-size: 24rpx; color: var(--text); line-height: 1.55; }
.lc-line .lc-sound, .lc-cell .lc-sound { width: 36rpx; height: 36rpx; border-radius: 50%; background: var(--primary); color: #fff; flex: 0 0 auto; display: flex; align-items: center; justify-content: center; font-size: 18rpx; box-shadow: 0 5rpx 10rpx rgba(74,124,89,.30); opacity: .2; }

/* 导航按钮（手机 flip-center 右侧悬浮） */
.cards-stage.flip-center .nav-stack { position: absolute; right: 20rpx; top: 62%; transform: translateY(-50%); z-index: 10; display: flex; flex-direction: column; align-items: center; gap: 22rpx; }
.cards-stage.flip-center .nav-round { width: 60rpx; height: 60rpx; border-radius: 50%; background: rgba(74,124,89,.5); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.cards-stage.flip-center .nav-round.ghost { background: rgba(238,242,230,.5); border: 2rpx solid rgba(74,124,89,.5); }
.cards-stage.flip-center .nav-round.accent { background: rgba(232,168,124,.6); }
.cards-stage.flip-center .nav-round:active { transform: scale(.92); }

/* ===== 弹出层（手机） ===== */
.pop-mask.phone-mask { position: fixed; inset: 0; background: rgba(20,18,14,.90); z-index: 60; display: flex; align-items: center; justify-content: center; }
.pop-card { width: 100%; height: 100%; background: var(--bg); border-radius: 0; overflow: hidden; display: flex; flex-direction: column; position: relative; }
.pop-card .pop-close { position: absolute; top: 23rpx; right: 23rpx; z-index: 10; width: 59rpx; height: 59rpx; border-radius: 50%; background: rgba(0,0,0,.5); color: #fff; font-size: 31rpx; display: flex; align-items: center; justify-content: center; }
.pop-card .cards-stage { flex: 1; min-height: 0; width: 100%; }
.pop-card .cards-stage.flip-center .learn-card { padding-bottom: 80rpx; }

/* ============================================================
   📲 iPad .tablet — JS 显式高度 + ÷3 px 值 + 基础 flex
   ============================================================ */
.tablet .tablet-content { padding: 44px 60px 90px; }

/* 顶栏 */
.tablet .mode-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px; }
.tablet .mode-top .badge { background: var(--primary); color: #fff; font-size: 36px; font-weight: 600; padding: 18px 44px; border-radius: 999px; }
.tablet .mode-top .links { display: flex; gap: 18px; }
.tablet .mode-top .link { background: var(--card-bg); border: 2px solid #e0dcd4; color: var(--text); font-size: 33px; font-weight: 600; padding: 16px 32px; border-radius: 999px; }

/* 浏览网格 */
.tablet .browse-grid { display: grid; gap: 28px; }
.tablet .browse-grid.cols-6 { grid-template-columns: repeat(6, 1fr); gap: 24px; }
.tablet .browse-grid.cols-8 { grid-template-columns: repeat(8, 1fr); gap: 20px; }
.tablet .b-tile { aspect-ratio: 1; border-radius: 40px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.tablet .b-tile .bt-emoji { font-size: 132px; line-height: 1.1; }
.tablet .b-tile .bt-name { font-size: 40px; color: #fff; font-weight: 600; margin-top: 14px; text-shadow: 0 2px 6px rgba(0,0,0,.35); }
.tablet .b-tile .bt-flag { position: absolute; top: 16px; right: 18px; font-size: 34px; color: #fff; background: rgba(0,0,0,.35); border-radius: 50%; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }

/* ===== 卡片模式 ===== */
.tablet .ipad-card { display: flex; flex-direction: column; padding: 44px 60px 90px; position: relative; background: var(--bg); }
.tablet .ipad-card .fc-counter { text-align: center; font-size: 42px; color: var(--text-weak); margin-bottom: 28px; font-weight: 600; flex: none; }

.tablet .ipad-card .lc-image { flex: 1; min-height: 0; border-radius: 48px; background: linear-gradient(140deg,#eef3e4 0%,#dce7cf 100%); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.tablet .ipad-card .lc-image .lc-emoji { font-size: 520px; line-height: 1; }
.tablet .ipad-card .lc-image .lc-ph { position: absolute; bottom: 26px; left: 0; right: 0; text-align: center; font-size: 32px; color: var(--text-weak); opacity: .72; }
.tablet .ipad-card .lc-image .lc-zoom { position: absolute; bottom: 30px; right: 30px; width: 88px; height: 88px; z-index: 8; border-radius: 50%; background: rgba(255,255,255,.85); color: var(--primary); font-size: 44px; display: flex; align-items: center; justify-content: center; }

.tablet .ipad-card .lc-texts { position: absolute; left: 0; right: 0; bottom: 0; z-index: 4; background: linear-gradient(to top, rgba(245,240,232,.96) 58%, rgba(245,240,232,0)); padding: 64px 0 96px; display: flex; flex-direction: column; gap: 22px; }
.tablet .ipad-card .lc-zhen { display: flex; gap: 22px; }
.tablet .ipad-card .lc-cell { flex: 1; min-width: 0; display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 30px 38px; background: #faf8f3; border-radius: 34px; }
.tablet .ipad-card .lc-line { display: flex; align-items: center; justify-content: space-between; gap: 28px; padding: 30px 38px; background: #faf8f3; border-radius: 34px; }
.tablet .ipad-card .lc-cell-zh .lc-zh { font-size: 88px; font-weight: 700; color: var(--text); line-height: 1.15; }
.tablet .ipad-card .lc-cell-en .lc-en { font-size: 88px; color: var(--text); line-height: 1.15; }
.tablet .ipad-card .lc-line .lc-fact { font-size: 42px; color: var(--text); line-height: 1.55; }
.tablet .ipad-card .lc-line .lc-sound,
.tablet .ipad-card .lc-cell .lc-sound { width: 64px; height: 64px; border-radius: 50%; background: var(--primary); color: #fff; flex: 0 0 auto; display: flex; align-items: center; justify-content: center; font-size: 32px; box-shadow: 0 8px 18px rgba(74,124,89,.30); opacity: .2; }

.tablet .ipad-card .nav-stack { position: absolute; right: 36px; top: 62%; transform: translateY(-50%); z-index: 10; display: flex; flex-direction: column; align-items: center; gap: 38px; }
.tablet .ipad-card .nav-round { width: 105px; height: 105px; border-radius: 50%; background: rgba(74,124,89,.5); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 50px; }
.tablet .ipad-card .nav-round.ghost { background: rgba(238,242,230,.5); border: 3px solid rgba(74,124,89,.5); }
.tablet .ipad-card .nav-round.accent { background: rgba(232,168,124,.6); }

/* ===== 弹出层（iPad） ===== */
.tablet .pop-mask.tablet-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(20,18,14,.90); z-index: 60; }
.tablet .pop-card { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg); overflow: hidden; }
