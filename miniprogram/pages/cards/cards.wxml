/* pages/cards/cards.wxml - 卡片学习页（翻面 / 大图双模式）
   浏览模式（默认）：网格方阵 + 弹出详情
   卡片模式：全屏大图 + 三行发音横幅 + 翻页导航
   平板模式(.tablet 类)：图片铺满全屏、导航在右侧竖排 */

<view class="page-root {{isTablet ? 'tablet' : ''}}">
  <view class="container">
    <view class="topbar">
      <text class="link-back pill" bindtap="goBoards">📚 板块</text>
      <text class="progress">{{progress}}</text>
      <text class="link-stats pill" bindtap="goStats">📊 统计</text>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中…</view>

    <view wx:elif="{{cards.length === 0}}" class="empty">该板块暂无卡片</view>

    <view wx:else class="card-area">
      <view class="card {{flipped ? 'flipped' : ''}}" bindtap="onTapCard">
        <view class="card-inner">
          <view class="card-face card-front">
            <text class="card-label">问题</text>
            <text class="card-text">{{cards[index].front}}</text>
            <text class="card-hint">点击翻面看答案</text>
          </view>
          <view class="card-face card-back">
            <text class="card-label">答案</text>
            <text class="card-text">{{cards[index].back}}</text>
            <text class="card-hint">点击返回</text>
          </view>
        </view>
      </view>

      <view class="nav">
        <button class="nav-btn" bindtap="prev">← 上一张</button>
        <button class="nav-btn primary" bindtap="next">下一张 →</button>
      </view>
    </view>
  </view>
</view>
